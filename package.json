{
  "name": "@pranav271103/murphycode",
  "version": "3.4.3",
  "description": "Murphy - The High-Speed Coding Predator. An agentic coding platform powered by dual-model orchestration.",
  "type": "module",
  "bin": {
    "murphycode": "./dist/index.js",
    "murphy": "./dist/index.js"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pranav271103/Murphy.git"
  },
  "bugs": {
    "url": "https://github.com/pranav271103/Murphy.git/issues"
  },
  "homepage": "https://github.com/pranav271103/Murphy.git#readme",
  "main": "dist/index.js",
  "scripts": {
    "start": "tsx src/index.tsx",
    "dev": "tsx watch src/index.tsx",
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "build:watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "keywords": [
    "ai",
    "agent",
    "coding",
    "llm",
    "nvidia",
    "kimi",
    "qwen",
    "cli",
    "terminal",
    "predator"
  ],
  "author": "Murphy Team",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.5",
    "glob": "^10.3.10",
    "ink": "^5.0.1",
    "openai": "^4.47.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@vitest/ui": "^4.1.4",
    "eslint": "^10.2.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}