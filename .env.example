# NVIDIA NIM API Configuration
# Get your API key at: https://build.nvidia.com/

# Primary API Key (used for both models if specific keys not set)
NVIDIA_API_KEY=your_nvidia_api_key_here

# Optional: Separate keys for each model
NVIDIA_API_KIMI=your_kimi_key_here
NVIDIA_API_QWEN=your_qwen_key_here

# Optional: Custom NVIDIA NIM endpoint
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Optional: Override default models
KIMI_MODEL=moonshotai/kimi-k2-thinking
QWEN_MODEL=qwen/qwen3-coder-480b-a35b-instruct

# Execution Settings
MAX_CONCURRENT_TOOLS=10
TOOL_TIMEOUT=120000
DEFAULT_CWD=.

# UI Settings
MURPHY_THEME=retro
MURPHY_TELEMETRY=true
MURPHY_DEBUG=false
